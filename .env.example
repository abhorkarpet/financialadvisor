# n8n Webhook Configuration
# Copy this file to .env and fill in your actual values

# Required: Your n8n webhook URL for financial statement processing (used in main app)
# Get this from your n8n workflow after setting up the webhook trigger
# Example: https://your-instance.app.n8n.cloud/webhook/financial-statement-upload
N8N_WEBHOOK_URL=

# Optional: Separate webhook URL for statement_uploader.py (standalone tool)
# If not set, falls back to N8N_WEBHOOK_URL
# Example: https://your-instance.app.n8n.cloud/webhook/statement-uploader
N8N_STATEMENT_UPLOADER_URL=

# Optional: Authentication token for webhook security
# Only needed if you configured webhook authentication in n8n
N8N_WEBHOOK_TOKEN=

# OpenAI API key for the chat advisor (Mode 2 simple planning) and Python statement processor
OPENAI_API_KEY=

# Set to 'true' to use the built-in Python processor instead of n8n (eliminates n8n subscription cost).
# When enabled, N8N_WEBHOOK_URL is not required. Requires OPENAI_API_KEY.
PYTHON_STATEMENT_PROCESSOR=
